# Owner: HADI
# Copy to .env and fill in values. Vault-sourced secrets override these at runtime.

# Vault (dev mode — root token only)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# Initial secrets (overwritten by Vault bootstrap in all containers)
POSTGRES_PASSWORD=postgres
JWT_SECRET=changeme-dev-secret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Ports exposed on host
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=8000
SFTP_PORT=2222
